---
import { getAllPosts } from '../lib/posts';
import KnowledgeGarden from '../components/KnowledgeGarden';
import '../styles/global.css';

const posts = await getAllPosts();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Drilon Maloku — Knowledge Garden</title>
    <meta name="description" content="Dentist. Builder. Writer. Explorer of ideas across borders and disciplines." />
    <meta property="og:title" content="Drilon Maloku — Knowledge Garden" />
    <meta property="og:description" content="Dentist. Builder. Writer. Explorer of ideas across borders and disciplines." />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <KnowledgeGarden posts={posts} client:load />
  </body>
</html>
